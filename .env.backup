# ==============================================
# Hardware Pipeline - Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values

# --- LLM API Keys ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx                    # For embeddings (text-embedding-3-large)
GLM_API_KEY=ef9bb2855a4c4fb6b41c0fbec2f03708.tJryP8doyZnJdgVC                          # ZhipuAI GLM-4 API key (https://open.bigmodel.cn)

# --- LLM Model Configuration ---
PRIMARY_MODEL=claude-opus-4-6
FAST_MODEL=claude-haiku-4-5-20251001
FALLBACK_MODEL=ollama/qwen2.5-coder:32b
LAST_RESORT_MODEL=glm-4

# --- Ollama (Air-Gap Fallback) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:32b

# --- GLM-4 (Last Resort Fallback) ---
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4

# --- Component Search APIs ---
DIGIKEY_CLIENT_ID=yweopo5NZzr3kl0RH0K0vx8w6p4bZLM4rXHSZgjMGWTbyE3n                    # DigiKey API v3 (https://developer.digikey.com)
DIGIKEY_CLIENT_SECRET=U2kzV1LbRRbQqRvfiGb0w2zx1FcPNG0dhEDUCG7lPcavj4rdG816tcK2C8Mqe4ia
DIGIKEY_API_URL=https://api.digikey.com/v3

MOUSER_API_KEY=a8883340-cccc-471c-a0f5-6eee8817b775                       # Mouser Search API (https://api.mouser.com)
MOUSER_API_URL=https://api.mouser.com/api/v2

# --- Database ---
# DATABASE_URL=postgresql://hardware_pipeline:password@localhost:5432/hardware_pipeline
# For SQLite fallback (no PostgreSQL needed):
DATABASE_URL=sqlite:///./hardware_pipeline.db

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=component_datasheets

# --- Embedding ---
EMBEDDING_MODEL=text-embedding-3-large     # Online mode
OFFLINE_EMBEDDING_MODEL=nomic-embed-text   # Air-gap mode

# --- Application ---
APP_NAME=Hardware Pipeline
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- Server ---
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
STREAMLIT_PORT=8501
